# Shared
ENV=development
TIMEZONE=UTC

# API/Dashboard auth
API_AUTH_TOKEN=change-me
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# Database / cache
POSTGRES_DB=voicecall
POSTGRES_USER=voicecall
POSTGRES_PASSWORD=voicecall
DATABASE_URL=postgresql+psycopg://voicecall:voicecall@postgres:5432/voicecall
REDIS_URL=redis://redis:6379/0

# LiveKit
LIVEKIT_URL=http://livekit-server:7880
LIVEKIT_WS_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_SIP_TRUNK_ID=ST00000000000000000000000000000000
LIVEKIT_WEBHOOK_SECRET=change-me-livekit-webhook
LIVEKIT_DEFAULT_ROOM_PREFIX=call

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550123

# Voice AI providers
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
WHISPER_BASE_URL=http://host.docker.internal:8001/v1
WHISPER_API_KEY=local-whisper
WHISPER_MODEL=whisper-1
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Retention / runtime
TRANSCRIPT_RETENTION_DAYS=30
MAX_CALL_DURATION_SECONDS=900
AGENT_FALLBACK_TEXT=I am sorry, I am having trouble right now. Please try again shortly.
